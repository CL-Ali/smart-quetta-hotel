# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# Required: used to sign session JWTs — change this to any long random string
JWT_SECRET=change-me-to-a-long-random-secret

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite database path (leave blank to use default: hotel.db in project root)
# When running via Docker this is set automatically to /app/data/hotel.db
DB_PATH=

# ─── OAuth (optional – leave blank to skip OAuth login) ──────────────────────
OAUTH_SERVER_URL=
VITE_APP_ID=
OWNER_OPEN_ID=
